<Window x:Class="ScreenTranslator.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ScreenTranslator 设置" Height="560" Width="450"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="百度翻译 API 配置" FontWeight="Bold" FontSize="14" Margin="0,0,0,10"/>

        <StackPanel Grid.Row="1" Margin="0,0,0,8">
            <TextBlock Text="App ID" Margin="0,0,0,4"/>
            <TextBox x:Name="TxtAppId" Padding="4"/>
        </StackPanel>

        <StackPanel Grid.Row="2" Margin="0,0,0,8">
            <TextBlock Text="Secret Key" Margin="0,0,0,4"/>
            <TextBox x:Name="TxtSecretKey" Padding="4"/>
        </StackPanel>

        <TextBlock Grid.Row="3" Text="目标窗口配置" FontWeight="Bold" FontSize="14" Margin="0,10,0,10"/>

        <StackPanel Grid.Row="4" Margin="0,0,0,8">
            <TextBlock Text="选择目标进程" Margin="0,0,0,4"/>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <ComboBox x:Name="CmbProcess" Grid.Column="0" Padding="4" IsEditable="True"
                          DisplayMemberPath="DisplayName"/>
                <Button Grid.Column="1" Content="刷新" Width="50" Height="30" Margin="8,0,0,0"
                        Click="OnRefreshProcesses"/>
            </Grid>
            <TextBlock Text="留空 = 全屏 OCR（翻译整个桌面）" FontSize="11" Foreground="Gray" Margin="0,4,0,0"/>
        </StackPanel>

        <StackPanel Grid.Row="5" Margin="0,0,0,8">
            <TextBlock Text="刷新间隔（毫秒）" Margin="0,0,0,4"/>
            <TextBox x:Name="TxtRefreshInterval" Padding="4"/>
        </StackPanel>

        <TextBlock Grid.Row="6" Text="显示样式" FontWeight="Bold" FontSize="14" Margin="0,10,0,10"/>

        <StackPanel Grid.Row="7" Margin="0,0,0,8">
            <TextBlock Text="字体大小" Margin="0,0,0,4"/>
            <TextBox x:Name="TxtFontSize" Padding="4"/>
        </StackPanel>

        <StackPanel Grid.Row="8" Margin="0,0,0,8">
            <TextBlock Text="字体颜色（如 #FFFFFF）" Margin="0,0,0,4"/>
            <TextBox x:Name="TxtFontColor" Padding="4"/>
        </StackPanel>

        <StackPanel Grid.Row="9" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="保存" Width="80" Height="30" Margin="0,0,10,0" Click="OnSaveClick"/>
            <Button Content="取消" Width="80" Height="30" Click="OnCancelClick"/>
        </StackPanel>
    </Grid>
</Window>
